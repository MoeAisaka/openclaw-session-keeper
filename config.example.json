{
  "schemaVersion": 2,
  "enabled": true,
  "sessionsStorePath": "~/.openclaw/agents/main/sessions/sessions.json",
  "codexStateDbPath": null,
  "routerStatePath": "~/.openclaw/model-router/session-state.json",
  "workflowTaskDir": "~/.openclaw/workspace/memory/workflow-ledger/tasks",
  "stateRoot": "~/.openclaw/session-keeper",
  "recoveryRoot": "~/.openclaw/session-keeper/recoveries",
  "openclawBin": "openclaw",
  "nmemBin": "nmem",
  "sessionPreferences": {
    "thinkingLevel": null,
    "fastMode": false
  },
  "visibleContinuity": {
    "enabled": true,
    "label": "Session rollover",
    "historyCheckLimit": 200,
    "repairExistingSessionKeys": []
  },
  "rolloverTiming": {
    "deferUntilNextUserMessage": true
  },
  "thresholds": {
    "checkpointTokens": 190000,
    "rolloverTokens": 235000,
    "emergencyTokens": 255000,
    "checkpointTranscriptBytes": 8388608,
    "rolloverTranscriptBytes": 16777216,
    "emergencyTranscriptBytes": 33554432,
    "maxPhysicalAgeDays": 45,
    "minIdleSeconds": 120,
    "recentMessageCount": 12,
    "recentMessageChars": 30000,
    "continuityContextChars": 16000
  },
  "sessions": {
    "agent:main:project-example": {
      "label": "Example project",
      "project": "example",
      "query": "example project decisions and next steps",
      "allowManualModelOverride": true,
      "allowManualFastMode": true,
      "preferences": {
        "thinkingLevel": null,
        "fastMode": false
      }
    }
  }
}
