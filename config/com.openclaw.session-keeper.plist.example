<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.openclaw.session-keeper</string>
  <key>ProgramArguments</key>
  <array>
    <string>__PYTHON__</string>
    <string>__REPOSITORY__/session_rollover.py</string>
    <string>scan</string>
  </array>
  <key>StartInterval</key>
  <integer>60</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>__HOME__/.openclaw/logs/session-keeper.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/.openclaw/logs/session-keeper.stderr.log</string>
</dict>
</plist>
